\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{leantex}[2026/02/27 LeanTeX package]
\newif\ifleantexonefile
\leantexonefilefalse
\DeclareOption{onefile}{\leantexonefiletrue}
\DeclareOption{isolated}{\leantexonefilefalse}
\ProcessOptions\relax

\RequirePackage{etoolbox}
\RequirePackage{comment}
\RequirePackage{iftex}
\RequirePackage{xcolor}
\RequirePackage{amssymb}
\RequirePackage{listings}
\RequirePackage{tcolorbox}
\ifPDFTeX
  \newcommand{\leantexmonofont}{\ttfamily}
\else
  \RequirePackage{fontspec}
  \IfFontExistsTF{JuliaMono}{
    \newfontfamily\leantexmonofont{JuliaMono}[Scale=MatchLowercase]
  }{
    \IfFontExistsTF{DejaVu Sans Mono}{
      \newfontfamily\leantexmonofont{DejaVu Sans Mono}[Scale=MatchLowercase]
    }{
      \IfFontExistsTF{Noto Sans Mono}{
        \newfontfamily\leantexmonofont{Noto Sans Mono}[Scale=MatchLowercase]
      }{
        \newfontfamily\leantexmonofont{Latin Modern Mono}[Scale=MatchLowercase]
      }
    }
  }
\fi

\newcounter{leantexblock}
\newcommand{\leantexenableonefile}{\global\leantexonefiletrue}
\newcommand{\leantexdisableonefile}{\global\leantexonefilefalse}

% Lean-inspired palette for listings.
\definecolor{leanKeyword}{HTML}{005A9C}
\definecolor{leanTactic}{HTML}{7A3E9D}
\definecolor{leanType}{HTML}{1E6B45}
\definecolor{leanCommand}{HTML}{8A4B0F}
\definecolor{leanComment}{HTML}{6B7280}
\definecolor{leanString}{HTML}{A13E00}
\newcommand{\leantex@defaultcodesize}{\small}
\newcommand{\leantexsetdefaultcodesize}[1]{\renewcommand{\leantex@defaultcodesize}{#1}}
\newcommand{\leantex@defaultoutsize}{\small}
\newcommand{\leantexsetdefaultoutputsize}[1]{\renewcommand{\leantex@defaultoutsize}{#1}}
\newcommand{\leantex@codeextras}{}
\newcommand{\leantex@outextras}{}
\newcommand{\leantexsetcodestyle}[1]{\renewcommand{\leantex@codeextras}{,#1}}
\newcommand{\leantexsetoutputstyle}[1]{\renewcommand{\leantex@outextras}{,#1}}
\newcommand{\leantexunicode}[1]{%
  \ifPDFTeX
    U+#1%
  \else
    {\leantexmonofont\char"#1}%
  \fi
}
\newcommand{\leantexmathcmdor}[2]{%
  \ifcsname #1\endcsname
    \ensuremath{\csname #1\endcsname}%
  \else
    \leantexunicode{#2}%
  \fi
}
\newcommand{\leantexunicodemapped}[1]{%
  \ifcsname leantex@unicode@#1\endcsname
    \csname leantex@unicode@#1\endcsname
  \else
    \leantexunicode{#1}%
  \fi
}
