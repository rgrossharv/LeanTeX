\newcommand{\leantexregisterunicode}[2]{%
  % Backward-compat shim for older generated files.
  \leantexsetdynamicliterate{{U+#1}{{\leantexunicodemapped{#1}}}#2}%
}

\lstdefinelanguage{lean}{
  alsoletter={\#,'?},
  morekeywords={
    theorem,def,lemma,example,axiom,abbrev,opaque,notation,macro,where,by,match,if,then,else,
    let,have,show,from,fun,forall,exists,do,return,mutual,unsafe,termination_by,decreasing_by,
    structure,class,instance,deriving,inductive,namespace,section,end,open,export,attribute,set_option,
    import,local,scoped,in,variable,variables,universe,universes,noncomputable
  },
  morekeywords=[2]{
    intro,intros,exact,refine,apply,constructor,cases,cases',case,induction,revert,rename_i,subst,
    simp,simpa,simp_all,rw,nth_rewrite,change,conv,ring,linarith,nlinarith,omega,positivity,
    decide,aesop,trivial,tauto,assumption,contradiction,left,right,first,next,repeat,all_goals,
    any_goals,try,guard_hyp,guard_target,rfl,rcases,obtain,calc,simpa?,simp?
  },
  morekeywords=[3]{
    Type,Prop,Sort,True,False,Nat,Int,Rat,Real,Bool,String,List,Option,Finset,Set
  },
  morekeywords=[4]{\#check,\#eval,\#print,\#reduce,\#synth,\#guard,\#help,\#where},
  otherkeywords={:=,=>,->,<-,|},
  sensitive=true,
  morecomment=[l]{--},
  morecomment=[s]{/-}{-/},
  morestring=[b]"
}

\leantexsetdynamicliterate{}

\lstdefinestyle{leantexcode}{
  language=lean,
  basicstyle=\leantexmonofont\small,
  keywordstyle=\bfseries\color{leanKeyword},
  keywordstyle=[2]\color{leanTactic},
  keywordstyle=[3]\color{leanType},
  keywordstyle=[4]\color{leanCommand},
  commentstyle=\itshape\color{leanComment},
  stringstyle=\color{leanString},
  rulecolor=\color{black!20},
  numbers=none,
  xleftmargin=0.6em,
  framexleftmargin=0.3em,
  framesep=3pt,
  columns=fullflexible,
  keepspaces=true,
  showstringspaces=false,
  frame=single,
  framerule=0.4pt,
  breaklines=true
}

\lstdefinestyle{leantexout}{
  basicstyle=\leantexmonofont\small,
  rulecolor=\color{black!20},
  columns=fullflexible,
  keepspaces=true,
  showstringspaces=false,
  frame=single,
  framerule=0.4pt,
  breaklines=true
}

\newif\ifleantexautobuild
\leantexautobuildtrue
\newcommand{\leantex@buildcommand}{python3 -m leantex build "\jobname.tex" --no-latexmk}
\newcommand{\leantexsetbuildcommand}[1]{\renewcommand{\leantex@buildcommand}{#1}}
\newcommand{\leantexenableautobuild}{\leantexautobuildtrue}
\newcommand{\leantexdisableautobuild}{\leantexautobuildfalse}
\newif\ifleantex@loadedgenerated
\leantex@loadedgeneratedfalse
\newcommand{\leantex@autobuildgenerated}{%
  \begingroup
    \newif\ifleantex@shellescape
    \leantex@shellescapefalse
    \ifdefined\pdfshellescape
      \ifnum\pdfshellescape=1\relax
        \leantex@shellescapetrue
      \fi
    \else
      \ifdefined\shellescape
        \ifnum\shellescape=1\relax
          \leantex@shellescapetrue
        \fi
      \fi
    \fi
    \ifleantex@shellescape
      \immediate\write18{\leantex@buildcommand}%
    \else
      \PackageWarningNoLine{leantex}{%
        leantex.generated.tex missing and unrestricted shell-escape is not enabled.\MessageBreak
        Run `leantex build \jobname.tex` (or use latexmk hook) first%
      }%
    \fi
  \endgroup
}
\newcommand{\leantexloadgenerated}{%
  \ifleantex@loadedgenerated\else
    \ifcsname leantex@generatedloaded\endcsname
      \global\leantex@loadedgeneratedtrue
    \fi
  \fi
  \ifleantex@loadedgenerated\else
    \IfFileExists{leantex.generated.tex}{}{%
      \ifleantexautobuild
        \leantex@autobuildgenerated
      \fi
    }%
    \InputIfFileExists{leantex.generated.tex}{%
      \global\leantex@loadedgeneratedtrue
    }{%
      \PackageWarningNoLine{leantex}{%
        leantex.generated.tex not found.\MessageBreak
        Lean blocks will show "Missing generated data" placeholders%
      }%
    }%
  \fi
}
\AtBeginDocument{\leantexloadgenerated}

\newcommand{\leantex@get}[2]{%
  \ifcsname leantex@#1@#2\endcsname
    \csname leantex@#1@#2\endcsname
  \else
    \relax
  \fi
}

\newcommand{\leantex@render}[1]{%
  \ifcsname leantex@codepath@#1\endcsname
    \edef\lltshow{\leantex@get{show}{#1}}%
    \edef\lltcodepath{\leantex@get{codepath}{#1}}%
    \edef\lltcoderawpath{\leantex@get{coderawpath}{#1}}%
    \edef\lltoutpath{\leantex@get{outpath}{#1}}%
    \edef\lltoutrawpath{\leantex@get{outrawpath}{#1}}%
    \edef\llthaserror{\leantex@get{haserror}{#1}}%
    \def\lltcodeviewpath{\lltcodepath}%
    \def\lltoutviewpath{\lltoutpath}%
    \ifPDFTeX\else
      \ifcsname leantex@coderawpath@#1\endcsname
        \edef\lltcodeviewpath{\lltcoderawpath}%
      \fi
      \ifcsname leantex@outrawpath@#1\endcsname
        \edef\lltoutviewpath{\lltoutrawpath}%
      \fi
    \fi
    \def\lltcodesizecmd{\leantex@defaultcodesize}%
    \ifcsname leantex@codesize@#1\endcsname
      \expandafter\let\expandafter\lltcodesizecmd\csname leantex@codesize@#1\endcsname
    \fi
    \def\lltoutsizecmd{\leantex@defaultoutsize}%
    \ifcsname leantex@outsize@#1\endcsname
      \expandafter\let\expandafter\lltoutsizecmd\csname leantex@outsize@#1\endcsname
    \fi

    \ifdefstrequal{\lltshow}{output}{}{%
      \begin{tcolorbox}[colback=gray!2!white,colframe=black!35,title=Lean Code]
        \lstinputlisting[style=leantexcode,basicstyle=\leantexmonofont\lltcodesizecmd\leantex@codeextras]{\lltcodeviewpath}
      \end{tcolorbox}
    }%

    \ifdefstrequal{\lltshow}{code}{}{%
      \ifdefstrequal{\llthaserror}{1}{%
        \begin{tcolorbox}[colback=red!2!white,colframe=red!60!black,title=Infoview Output]
          \lstinputlisting[style=leantexout,basicstyle=\leantexmonofont\lltoutsizecmd\leantex@outextras]{\lltoutviewpath}
        \end{tcolorbox}
      }{%
        \begin{tcolorbox}[colback=blue!2!white,colframe=blue!45!black,title=Infoview Output]
          \lstinputlisting[style=leantexout,basicstyle=\leantexmonofont\lltoutsizecmd\leantex@outextras]{\lltoutviewpath}
        \end{tcolorbox}
      }%
    }%
  \else
    \begin{tcolorbox}[colback=yellow!5!white,colframe=yellow!50!black,title=LeanTeX]
      Missing generated data for block #1. Run \texttt{leantex build} first.
    \end{tcolorbox}
  \fi
}

\newcommand{\totalinfoview}[1][Extracted Lean Infoview]{%
  \ifcsname leantex@extractedoutpath\endcsname
    \edef\lltoutviewpath{\csname leantex@extractedoutpath\endcsname}%
    \edef\llthaserror{\csname leantex@extractedhaserror\endcsname}%
    \ifPDFTeX\else
      \ifcsname leantex@extractedoutrawpath\endcsname
        \edef\lltoutviewpath{\csname leantex@extractedoutrawpath\endcsname}%
      \fi
    \fi
    \def\lltoutsizecmd{\leantex@defaultoutsize}%
    \ifdefstrequal{\llthaserror}{1}{%
      \begin{tcolorbox}[colback=red!2!white,colframe=red!60!black,title=#1]
        \lstinputlisting[style=leantexout,basicstyle=\leantexmonofont\lltoutsizecmd\leantex@outextras]{\lltoutviewpath}
      \end{tcolorbox}
    }{%
      \begin{tcolorbox}[colback=blue!2!white,colframe=blue!45!black,title=#1]
        \lstinputlisting[style=leantexout,basicstyle=\leantexmonofont\lltoutsizecmd\leantex@outextras]{\lltoutviewpath}
      \end{tcolorbox}
    }%
  \else
    \begin{tcolorbox}[colback=yellow!5!white,colframe=yellow!50!black,title=LeanTeX]
      Missing extracted infoview data. Run \texttt{leantex build} first.
    \end{tcolorbox}
  \fi
}
\let\leantexshowextractedinfoview\totalinfoview

\newenvironment{lean}[1][]{%
  \stepcounter{leantexblock}%
  \leantex@render{\arabic{leantexblock}}%
  \comment
}{%
  \endcomment
}
