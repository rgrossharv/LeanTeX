\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{leantexv2}[2026/04/04 LeanTeX v2 -- minted-based Lean 4 integration]

% ────────────────────────────────────────────────────────────
%  Options
% ────────────────────────────────────────────────────────────
\newif\ifleantexonefile
\leantexonefilefalse
\DeclareOption{onefile}{\leantexonefiletrue}
\DeclareOption{isolated}{\leantexonefilefalse}
\ProcessOptions\relax

% ────────────────────────────────────────────────────────────
%  Required packages (user needs NOTHING else)
% ────────────────────────────────────────────────────────────
\RequirePackage{etoolbox}
\RequirePackage{comment}
\RequirePackage{iftex}
\RequirePackage{xcolor}
\RequirePackage{amssymb}
\RequirePackage{tcolorbox}
\tcbuselibrary{skins}
\RequirePackage{minted}
\RequirePackage{newunicodechar}

% Require a Unicode engine
\ifPDFTeX
  \PackageError{leantexv2}{%
    leantexv2 requires XeLaTeX or LuaLaTeX for Unicode support.%
    \MessageBreak Use: xelatex --shell-escape yourfile.tex%
  }{Switch to xelatex or lualatex and recompile.}
\fi

% ────────────────────────────────────────────────────────────
%  Font setup (fontspec -- XeTeX/LuaTeX only)
% ────────────────────────────────────────────────────────────
\RequirePackage{fontspec}
\IfFontExistsTF{JuliaMono}{%
  \newfontfamily\leantexmonofont{JuliaMono}[Scale=MatchLowercase]%
  \setmonofont{JuliaMono}[Scale=MatchLowercase]%
}{%
  \IfFontExistsTF{DejaVu Sans Mono}{%
    \newfontfamily\leantexmonofont{DejaVu Sans Mono}[Scale=MatchLowercase]%
    \setmonofont{DejaVu Sans Mono}[Scale=MatchLowercase]%
  }{%
    \IfFontExistsTF{Noto Sans Mono}{%
      \newfontfamily\leantexmonofont{Noto Sans Mono}[Scale=MatchLowercase]%
      \setmonofont{Noto Sans Mono}[Scale=MatchLowercase]%
    }{%
      \IfFontExistsTF{Menlo}{%
        \newfontfamily\leantexmonofont{Menlo}[Scale=MatchLowercase]%
        \setmonofont{Menlo}[Scale=MatchLowercase]%
      }{%
        \newfontfamily\leantexmonofont{Latin Modern Mono}[Scale=MatchLowercase]%
      }%
    }%
  }%
}

% ────────────────────────────────────────────────────────────
%  Unicode fallback: use STIX Two Math / Apple Symbols for
%  characters missing from the primary mono font
% ────────────────────────────────────────────────────────────
\newcommand{\leantex@fallbackchar}[1]{%
  {\leantex@unicodefallback #1}%
}
% Pick the best available fallback font for math/logic symbols
\IfFontExistsTF{STIX Two Math}{%
  \newfontfamily\leantex@unicodefallback{STIX Two Math}[Scale=MatchLowercase]%
}{%
  \IfFontExistsTF{Apple Symbols}{%
    \newfontfamily\leantex@unicodefallback{Apple Symbols}[Scale=MatchLowercase]%
  }{%
    \IfFontExistsTF{Symbola}{%
      \newfontfamily\leantex@unicodefallback{Symbola}[Scale=MatchLowercase]%
    }{%
      % Last resort: just use the mono font and accept missing glyphs
      \let\leantex@unicodefallback\leantexmonofont
    }%
  }%
}
