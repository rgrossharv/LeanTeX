\newcommand{\leantex@defaultcodesize}{\small}
\newcommand{\leantexsetdefaultcodesize}[1]{\renewcommand{\leantex@defaultcodesize}{#1}}
\newcommand{\leantex@defaultoutsize}{\small}
\newcommand{\leantexsetdefaultoutputsize}[1]{\renewcommand{\leantex@defaultoutsize}{#1}}

% Extra minted options for code / output (comma-separated key=value)
\newcommand{\leantex@mintedcodeopts}{}
\newcommand{\leantex@mintedoutopts}{}
\newcommand{\leantexsetcodestyle}[1]{\renewcommand{\leantex@mintedcodeopts}{,#1}}
\newcommand{\leantexsetoutputstyle}[1]{\renewcommand{\leantex@mintedoutopts}{,#1}}

% Minted style override
\newcommand{\leantexsetmintedstyle}[1]{\usemintedstyle{#1}}

% ────────────────────────────────────────────────────────────
%  Auto-build machinery (identical to v1)
% ────────────────────────────────────────────────────────────
\newif\ifleantexautobuild
\leantexautobuildtrue
\newcommand{\leantex@buildcommand}{python3 -m leantex build "\jobname.tex" --no-latexmk}
\newcommand{\leantexsetbuildcommand}[1]{\renewcommand{\leantex@buildcommand}{#1}}
\newcommand{\leantexenableautobuild}{\leantexautobuildtrue}
\newcommand{\leantexdisableautobuild}{\leantexautobuildfalse}

\newif\ifleantex@loadedgenerated
\leantex@loadedgeneratedfalse
\newcommand{\leantex@autobuildgenerated}{%
  \begingroup
    \newif\ifleantex@shellescape
    \leantex@shellescapefalse
    \ifdefined\pdfshellescape
      \ifnum\pdfshellescape=1\relax
        \leantex@shellescapetrue
      \fi
    \else
      \ifdefined\shellescape
        \ifnum\shellescape=1\relax
          \leantex@shellescapetrue
        \fi
      \fi
    \fi
    \ifleantex@shellescape
      \immediate\write18{\leantex@buildcommand}%
    \else
      \PackageWarningNoLine{leantexv2}{%
        leantexv2.generated.tex missing and unrestricted shell-escape is not enabled.\MessageBreak
        Run `leantex build \jobname.tex` (or use latexmk hook) first%
      }%
    \fi
  \endgroup
}
\newcommand{\leantexloadgenerated}{%
  \ifleantex@loadedgenerated\else
    \ifcsname leantex@generatedloaded\endcsname
      \global\leantex@loadedgeneratedtrue
    \fi
  \fi
  \ifleantex@loadedgenerated\else
    \IfFileExists{leantexv2.generated.tex}{}{%
      \ifleantexautobuild
        \leantex@autobuildgenerated
      \fi
    }%
    \InputIfFileExists{leantexv2.generated.tex}{%
      \global\leantex@loadedgeneratedtrue
    }{%
      \PackageWarningNoLine{leantexv2}{%
        leantexv2.generated.tex not found.\MessageBreak
        Lean blocks will show "Missing generated data" placeholders%
      }%
    }%
  \fi
}
\AtBeginDocument{\leantexloadgenerated}

% ────────────────────────────────────────────────────────────
%  Internal accessors
% ────────────────────────────────────────────────────────────
\newcommand{\leantex@get}[2]{%
  \ifcsname leantex@#1@#2\endcsname
    \csname leantex@#1@#2\endcsname
  \else
    \relax
  \fi
}

% ────────────────────────────────────────────────────────────
%  Code block rendering (minted via \inputminted)
% ────────────────────────────────────────────────────────────
\newcommand{\leantex@rendercode}[2]{%
  % #1 = font size command, #2 = file path
  \begin{tcolorbox}[
    colback=leantexCodeBg,
    colframe=leantexCodeFrame,
    boxrule=0.4pt,
    arc=1.5pt,
    left=0pt,
    right=0pt,
    top=0pt,
    bottom=0pt,
    boxsep=0pt,
    toptitle=2pt,
    bottomtitle=2pt,
    title={\sffamily\small\bfseries Lean},
    colbacktitle=leantexCodeTitleBg,
    coltitle=white
  ]
    \inputminted[
      fontsize=#1,
      breaklines=true,
      breakanywhere=true,
      tabsize=2\leantex@mintedcodeopts
    ]{lean4}{#2}
  \end{tcolorbox}
}

% ────────────────────────────────────────────────────────────
%  Infoview output rendering (minted text mode in tcolorbox)
% ────────────────────────────────────────────────────────────
\newcommand{\leantex@renderoutput}[3]{%
  % #1 = font size command, #2 = file path, #3 = has error (1/0)
  \ifnum#3=1\relax
    \def\leantex@outbg{leantexErrorBg}%
    \def\leantex@outframe{leantexErrorFrame}%
    \def\leantex@outtitlebg{leantexErrorTitleBg}%
    \def\leantex@outtitle{Infoview Output}%
  \else
    \def\leantex@outbg{leantexInfoBg}%
    \def\leantex@outframe{leantexInfoFrame}%
    \def\leantex@outtitlebg{leantexCodeTitleBg}%
    \def\leantex@outtitle{Infoview Output}%
  \fi
  \begin{tcolorbox}[
    colback=\leantex@outbg,
    colframe=\leantex@outframe,
    boxrule=0.4pt,
    arc=1.5pt,
    left=0pt,
    right=0pt,
    top=0pt,
    bottom=0pt,
    boxsep=0pt,
    toptitle=2pt,
    bottomtitle=2pt,
    title={\sffamily\small\bfseries \leantex@outtitle},
    colbacktitle=\leantex@outtitlebg,
    coltitle=white
  ]
    \inputminted[
      fontsize=#1,
      breaklines=true,
      breakanywhere=true,
      tabsize=2\leantex@mintedoutopts
    ]{text}{#2}
  \end{tcolorbox}
}

% ────────────────────────────────────────────────────────────
%  Main render dispatch
% ────────────────────────────────────────────────────────────
\newcommand{\leantex@showoutput}{output}
\newcommand{\leantex@showcode}{code}
\newcommand{\leantex@render}[1]{%
  \ifcsname leantex@codepath@#1\endcsname
    \edef\lltshow{\leantex@get{show}{#1}}%
    \edef\lltcoderawpath{\leantex@get{coderawpath}{#1}}%
    \edef\lltoutrawpath{\leantex@get{outrawpath}{#1}}%
    \edef\llthaserror{\leantex@get{haserror}{#1}}%
    %
    \def\lltcodesizecmd{\leantex@defaultcodesize}%
    \ifcsname leantex@codesize@#1\endcsname
      \expandafter\let\expandafter\lltcodesizecmd\csname leantex@codesize@#1\endcsname
    \fi
    \def\lltoutsizecmd{\leantex@defaultoutsize}%
    \ifcsname leantex@outsize@#1\endcsname
      \expandafter\let\expandafter\lltoutsizecmd\csname leantex@outsize@#1\endcsname
    \fi
    %
    % Show code block (unless show=output)
    \ifdefstrequal{\lltshow}{\leantex@showoutput}{}{%
      \leantex@rendercode{\lltcodesizecmd}{\lltcoderawpath}%
    }%
    %
    % Show output block (unless show=code)
    \ifdefstrequal{\lltshow}{\leantex@showcode}{}{%
      \leantex@renderoutput{\lltoutsizecmd}{\lltoutrawpath}{\llthaserror}%
    }%
  \else
    \begin{tcolorbox}[
      colback=leantexWarnBg,
      colframe=leantexWarnFrame,
      boxrule=0.4pt,
      arc=1.5pt,
      toptitle=2pt,
      bottomtitle=2pt,
      title={\sffamily\small\bfseries LeanTeX v2},
      colbacktitle=leantexWarnTitleBg,
      coltitle=white
    ]
      Missing generated data for block #1. Run \texttt{leantex build} first.
    \end{tcolorbox}
  \fi
}

% ────────────────────────────────────────────────────────────
%  Total infoview
% ────────────────────────────────────────────────────────────
\newcommand{\totalinfoview}[1][Extracted Lean Infoview]{%
  \ifcsname leantex@extractedoutrawpath\endcsname
    \edef\lltoutviewpath{\csname leantex@extractedoutrawpath\endcsname}%
    \edef\llthaserror{\csname leantex@extractedhaserror\endcsname}%
    \def\lltoutsizecmd{\leantex@defaultoutsize}%
    \leantex@renderoutput{\lltoutsizecmd}{\lltoutviewpath}{\llthaserror}%
  \else
    \begin{tcolorbox}[colback=leantexWarnBg,colframe=leantexWarnFrame,title=LeanTeX v2]
      Missing extracted infoview data. Run \texttt{leantex build} first.
    \end{tcolorbox}
  \fi
}
\let\leantexshowextractedinfoview\totalinfoview

% ────────────────────────────────────────────────────────────
%  The lean environment
% ────────────────────────────────────────────────────────────
\newenvironment{lean}[1][]{%
  \stepcounter{leantexblock}%
  \leantex@render{\arabic{leantexblock}}%
  \comment
}{%
  \endcomment
}
